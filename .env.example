FIREFLY_BASE_URL=http://your-firefly-ip-or-hostname
FIREFLY_TOKEN=your-personal-access-token
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret

# Port the app is exposed on (default: 3000)
APP_PORT=3000

# Optional: pull transactions from a specific start date on first sync
# SYNC_START_DATE=2023-01-01
