# ── Firefly III ───────────────────────────────────────────────────────────────
FIREFLY_BASE_URL=http://192.168.1.x:8080
FIREFLY_TOKEN=your-personal-access-token-from-firefly

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the bundled Postgres container (pick anything)
DB_PASSWORD=budget

# ── AI assistant (optional — can also configure Ollama in app Settings) ───────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── App port ───────────────────────────────────────────────────────────────────
APP_PORT=3000

# ── Cookie security ────────────────────────────────────────────────────────────
# Set to 'true' only if serving over HTTPS (e.g. behind a Cloudflare Tunnel)
# Leave as 'false' for plain HTTP on a local network
COOKIE_SECURE=false

# ── Sync ──────────────────────────────────────────────────────────────────────
# Uncomment to load full history from a specific date on first sync
# SYNC_START_DATE=2020-01-01
